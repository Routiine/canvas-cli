# Canvas CLI — Environment Variables
# Copy this file to .env and fill in your values

# AI Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional AI Providers
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
GOOGLE_API_KEY=

# Ollama (local LLM) configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=30000
OLLAMA_MODEL=llama3.2:latest

# GitHub integration (for canvas review-pr, canvas finetune, and git tools)
GITHUB_TOKEN=
GH_TOKEN=

# Dashboard server
# Comma-separated list of allowed CORS origins for the dashboard API server
ALLOWED_ORIGINS=http://localhost:3002
CANVAS_PORT=3000

# Runtime environment
NODE_ENV=development

# Optional: PostgreSQL (used with docker-compose --profile with-db)
POSTGRES_PASSWORD=

# Optional: Canvas session ID (set automatically by CLI; override for scripting)
# CANVAS_SESSION_ID=
