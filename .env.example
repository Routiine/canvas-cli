# Canvas CLI — Environment Variables
# Copy this file to .env and fill in your values

# AI Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional AI Providers
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# Langfuse Observability (optional)
# Get keys at https://cloud.langfuse.com — traces every LLM call with tokens/latency/cost
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Override to point at a self-hosted Langfuse instance
LANGFUSE_BASE_URL=

# mem0 Persistent Memory (optional)
# Get your API key at https://app.mem0.ai
# If unset, falls back to local LLM-powered memory at ~/.canvas/memories/
MEM0_API_KEY=
# Override the mem0 API base URL (e.g. for self-hosted mem0)
MEM0_BASE_URL=

# e2b Code Sandbox (optional)
# Enables sandboxed execution for AI-generated code via isolated cloud microVMs.
# When set, the `sandboxed_shell` tool is available and `run_shell_command`
# accepts useSandbox: true to route commands through e2b instead of the host.
# Get your key at: https://e2b.dev
E2B_API_KEY=

# Stagehand AI-Native Browser Automation (optional)
# When set, Stagehand uses Browserbase cloud for browser sessions.
# When absent, Stagehand falls back to a local Playwright/Chromium instance
# (no API key required for local mode).
# Get your keys at: https://browserbase.com
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
