{
  "name": "canvas-cli",
  "version": "3.0.0",
  "description": "Production-ready AI CLI with advanced features inspired by goose-cli",
  "main": "dist/index.js",
  "bin": {
    "canvas": "dist/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dashboard": "tsx src/dashboard/production-server.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "ai",
    "cli",
    "ollama",
    "llm",
    "assistant",
    "automation",
    "production",
    "enterprise"
  ],
  "author": "Canvas CLI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/canvas-cli/canvas-cli.git"
  },
  "bugs": {
    "url": "https://github.com/canvas-cli/canvas-cli/issues"
  },
  "homepage": "https://github.com/canvas-cli/canvas-cli#readme",
